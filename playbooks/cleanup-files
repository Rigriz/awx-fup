---
- hosts: L31,L32,L33,L42
  become: yes
  tasks:
    - name: 1. Remove old Fedora firmware and update logs
      shell: |
        rm -rf /boot/efi/EFI/fedora/fw/*
        rm -f /boot/efi/EFI/fedora/fwupd*
      ignore_errors: yes

    - name: 2. Remove unused Microsoft Fonts and Language packs
      shell: |
        rm -rf /boot/efi/EFI/Microsoft/Boot/Fonts
        rm -rf /boot/efi/EFI/Microsoft/Boot/ja-JP
        rm -rf /boot/efi/EFI/Microsoft/Boot/ko-KR
        rm -rf /boot/efi/EFI/Microsoft/Boot/zh-TW
        rm -rf /boot/efi/EFI/Microsoft/Boot/zh-CN
      ignore_errors: yes

    - name: 3. Remove oldest kernels (keep only latest 2)
      shell: dnf remove $(dnf repoquery --installonly --latest-limit=-2 -q) -y
      ignore_errors: yes

    - name: 4. Check available space on /boot/efi
      shell: df -h /boot/efi
      register: efi_space

    - name: 5. Display remaining space
      debug:
        var: efi_space.stdout_lines
